# Feedback function environment (set these in the Vercel dashboard, not committed).
ANTHROPIC_API_KEY=
# Fine-grained PAT on the crr-radar repo only, with:
#   Contents: Read and write   (commit the markdown report)
#   Issues:   Read and write   (mirror each report as a labeled issue)
GITHUB_TOKEN=
GITHUB_REPO=Johan246/crr-radar
GITHUB_BRANCH=main
# Lock the endpoint to your dashboard origin so other sites can't use it.
ALLOWED_ORIGIN=https://johan246.github.io
FEEDBACK_MODEL=claude-haiku-4-5-20251001
# Set to "false" to skip the GitHub issue mirror (report is still committed).
FEEDBACK_ISSUES=true
